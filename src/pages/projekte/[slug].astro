---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";

import SiteFooter from "../../components/chrome/SiteFooter.astro";
import SiteHeader from "../../components/chrome/SiteHeader.astro";
import Icon from "../../components/Icon.astro";
import ProjectMetaRail from "../../components/projects/ProjectMetaRail.astro";
import ProjectVisualAnchor from "../../components/projects/ProjectVisualAnchor.astro";
import { pageNavigation } from "../../data/navigation";
import { site } from "../../data/site";
import {
  getProjectContextLead,
  getProjectDetailLead,
  getProjectMetaLine,
  getProjectReferenceLinks,
} from "../../lib/projects";
import BaseLayout from "../../layouts/BaseLayout.astro";

type Props = {
  project: CollectionEntry<"projects">;
};

export async function getStaticPaths() {
  const projects = await getCollection("projects");

  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props as Props;
const { Content } = await project.render();
const projectLead = getProjectDetailLead(project);
const projectContextLead = getProjectContextLead(project);
const referenceLinks = getProjectReferenceLinks(project);
const primaryLinks = referenceLinks.filter((link) => link.emphasis !== "tertiary");
const overviewLink =
  referenceLinks.find((link) => link.emphasis === "tertiary") ?? null;
---

<BaseLayout
  title={`${project.data.title} - Projekte - ${site.domain}`}
  description={project.data.summary}
  canonicalPath={`/projekte/${project.slug}/`}
>
  <SiteHeader links={pageNavigation} />

  <main id="main" tabindex="-1" class="py-14 sm:py-20">
    <article
      class="mx-auto max-w-[80rem] px-5 sm:px-6 min-[1440px]:max-w-[84rem]"
    >
      <div class="xl:grid xl:grid-cols-[minmax(0,1.08fr)_minmax(18rem,0.52fr)] xl:gap-14 min-[1440px]:gap-16">
        <div class="min-w-0">
          <header class="border-b border-border/68 pb-10">
            <p class="meta reveal">Projekt</p>
            <p
              class="mt-4 text-[0.84rem] tracking-[0.08em] text-muted/92 reveal"
              style="--reveal-delay: 40ms"
            >
              {project.data.meta}
            </p>
            <h1
              class="mt-5 max-w-[12ch] text-[clamp(2.8rem,4.8vw,5rem)] font-[var(--w-title)] tracking-[-0.045em] leading-[0.94] reveal"
              style="--reveal-delay: 80ms"
            >
              {project.data.title}
            </h1>
            <p
              class="mt-6 max-w-[42rem] text-[clamp(1.08rem,1.46vw,1.24rem)] leading-[1.82] text-muted reveal"
              style="--reveal-delay: 120ms"
            >
              {projectLead}
            </p>

            <div
              class="mt-7 flex flex-wrap gap-x-5 gap-y-2 text-[0.88rem] tracking-[0.04em] text-muted/92 reveal"
              style="--reveal-delay: 150ms"
            >
              <span>{getProjectMetaLine(project)}</span>
              {
                project.data.tags.length ? (
                  <>
                    <span aria-hidden="true" class="text-border/80"> / </span>
                    <span>{project.data.tags.join(" / ")}</span>
                  </>
                ) : null
              }
            </div>

            {
              primaryLinks.length || overviewLink ? (
                <div
                  class="mt-9 flex flex-wrap items-center gap-x-6 gap-y-4 reveal"
                  style="--reveal-delay: 180ms"
                >
                  {primaryLinks.map((link) => (
                    <a
                      href={link.href}
                      class="group inline-flex items-center gap-3 text-[0.95rem] font-[430] tracking-[0.02em] text-text transition-colors hover:text-[rgb(var(--color-accent-soft))]"
                      {...(link.external
                        ? { target: "_blank", rel: "noopener noreferrer" }
                        : {})}
                    >
                      <span
                        aria-hidden="true"
                        class="h-px w-12 bg-border/78 transition-colors duration-200 group-hover:bg-accent/58"
                      ></span>
                      <span>{link.label}</span>
                      <span class="text-[0.68rem] uppercase tracking-[0.12em] text-muted/72">
                        {link.external ? "Extern" : "Intern"}
                      </span>
                      <Icon
                        name={link.external ? "external" : "arrowRight"}
                        size={15}
                        strokeWidth={1.2}
                        class="transition-transform duration-200 group-hover:translate-x-[0.1rem]"
                      />
                    </a>
                  ))}

                  {
                    overviewLink ? (
                      <a href={overviewLink.href} class="u-link-muted text-[0.9rem]">
                        {overviewLink.label}
                      </a>
                    ) : null
                  }
                </div>
              ) : null
            }
          </header>

          <ProjectVisualAnchor project={project} />

          <section
            class="reveal mt-12 border-b border-border/60 pb-10 xl:mt-14 xl:pb-12"
            style="--reveal-delay: 240ms"
            aria-labelledby="project-context-title"
          >
            <p class="meta">Einordnung</p>
            <h2
              id="project-context-title"
              class="mt-4 max-w-[18ch] text-[clamp(2rem,3vw,2.85rem)] font-[var(--w-title)] tracking-[-0.03em] leading-[1.02]"
            >
              {projectContextLead}
            </h2>
            <p
              class="mt-5 max-w-[42rem] text-[1.04rem] leading-[1.82] text-muted"
            >
              {project.data.context}
            </p>
          </section>

          <div
            class="project-content max-w-none reveal mt-10"
            style="--reveal-delay: 300ms"
          >
            <Content />
          </div>
        </div>

        <ProjectMetaRail project={project} />
      </div>
    </article>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .project-content {
    max-width: 47rem;
    color: hsl(var(--muted));
    line-height: 1.82;
  }

  .project-content > :global(*:first-child) {
    margin-top: 0;
  }

  .project-content :global(h2),
  .project-content :global(h3),
  .project-content :global(h4) {
    margin-top: clamp(2.8rem, 5vw, 3.4rem);
    padding-top: 1.35rem;
    border-top: 1px solid rgb(var(--color-border) / 0.56);
    color: hsl(var(--text));
    font-family: var(--font-display);
    font-weight: var(--w-title);
    letter-spacing: -0.028em;
    line-height: 1.04;
  }

  .project-content :global(h2) {
    font-size: clamp(1.78rem, 2.3vw, 2.4rem);
  }

  .project-content :global(h3) {
    font-size: clamp(1.38rem, 1.8vw, 1.7rem);
  }

  .project-content :global(h2 + p),
  .project-content :global(h3 + p),
  .project-content :global(h4 + p) {
    color: rgb(var(--color-text) / 0.92);
    font-size: 1.04rem;
  }

  .project-content :global(p) + :global(p) {
    margin-top: 1rem;
  }

  .project-content :global(p) {
    max-width: 44rem;
  }

  .project-content :global(strong) {
    color: rgb(var(--color-text) / 0.96);
  }

  .project-content :global(ul),
  .project-content :global(ol) {
    margin-top: 1.1rem;
    margin-left: 1.1rem;
    max-width: 42rem;
  }

  .project-content :global(li::marker) {
    color: rgb(var(--color-accent-soft) / 0.78);
  }

  .project-content :global(li) + :global(li) {
    margin-top: 0.5rem;
  }

  .project-content :global(a) {
    color: hsl(var(--link));
    text-decoration: underline;
    text-decoration-thickness: var(--u-thickness);
    text-underline-offset: var(--u-offset);
    text-decoration-color: rgb(var(--link-rgb) / 0.58);
    transition:
      color 150ms ease,
      text-decoration-color 150ms ease;
  }

  .project-content :global(a:hover),
  .project-content :global(a:focus-visible) {
    color: rgb(var(--link-hover-rgb));
    text-decoration-color: rgb(var(--link-hover-rgb) / 0.9);
  }
</style>
