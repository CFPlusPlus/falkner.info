---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";

import SiteFooter from "../../components/chrome/SiteFooter.astro";
import SiteHeader from "../../components/chrome/SiteHeader.astro";
import { pageNavigation } from "../../data/navigation";
import { site } from "../../data/site";
import BaseLayout from "../../layouts/BaseLayout.astro";

type Props = {
  project: CollectionEntry<"projects">;
};

export async function getStaticPaths() {
  const projects = await getCollection("projects");

  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props as Props;
const { Content } = await project.render();
---

<BaseLayout
  title={`${project.data.title} - Projekte - ${site.domain}`}
  description={project.data.summary}
  canonicalPath={`/projekte/${project.slug}/`}
>
  <SiteHeader links={pageNavigation} />

  <main id="main" tabindex="-1" class="py-14 sm:py-20">
    <article class="mx-auto max-w-4xl px-5">
      <p class="meta reveal">Projekt</p>
      <h1 class="mt-4 text-4xl sm:text-5xl font-[var(--w-title)] tracking-tight reveal" style="--reveal-delay: 60ms">
        {project.data.title}
      </h1>
      <p class="mt-5 text-muted leading-relaxed reveal" style="--reveal-delay: 100ms">
        {project.data.summary}
      </p>

      <div class="mt-6 flex flex-wrap gap-3 text-sm text-muted reveal" style="--reveal-delay: 130ms">
        <span>{project.data.year}</span>
        <span>/</span>
        <span>{project.data.status}</span>
        {project.data.tags.length ? (
          <>
            <span>/</span>
            <span>{project.data.tags.join(" / ")}</span>
          </>
        ) : null}
      </div>

      {project.data.externalUrl ? (
        <p class="mt-4 reveal" style="--reveal-delay: 150ms">
          <a class="u-link" href={project.data.externalUrl} target="_blank" rel="noopener noreferrer">
            Externes Projekt aufrufen
          </a>
        </p>
      ) : null}

      <div class="project-content mt-12 max-w-none reveal" style="--reveal-delay: 180ms">
        <Content />
      </div>

      <p class="mt-12">
        <a class="u-link" href="/projekte">Zurueck zur Projektuebersicht</a>
      </p>
    </article>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .project-content {
    color: hsl(var(--muted));
    line-height: 1.75;
  }

  .project-content :global(h2),
  .project-content :global(h3),
  .project-content :global(h4) {
    margin-top: 2rem;
    color: hsl(var(--text));
    font-family: var(--font-display);
    font-weight: var(--w-title);
    letter-spacing: -0.02em;
  }

  .project-content :global(p) + :global(p) {
    margin-top: 1rem;
  }

  .project-content :global(ul),
  .project-content :global(ol) {
    margin-top: 1rem;
    margin-left: 1.25rem;
  }

  .project-content :global(li) + :global(li) {
    margin-top: 0.375rem;
  }

  .project-content :global(a) {
    color: hsl(var(--link));
    text-decoration: underline;
    text-underline-offset: var(--u-offset);
  }
</style>

