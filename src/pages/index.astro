---
import { getCollection } from "astro:content";

import SiteFooter from "../components/chrome/SiteFooter.astro";
import SiteHeader from "../components/chrome/SiteHeader.astro";
import HomeContact from "../components/home/HomeContact.astro";
import HomeHero from "../components/home/HomeHero.astro";
import HomeImpressions from "../components/home/HomeImpressions.astro";
import HomeProfile from "../components/home/HomeProfile.astro";
import HomeSelectedWork from "../components/home/HomeSelectedWork.astro";
import { homeContent } from "../data/home";
import { impressions } from "../data/impressions";
import { homeNavigation } from "../data/navigation";
import BaseLayout from "../layouts/BaseLayout.astro";

const projects = (await getCollection("projects")).sort((a, b) => {
  const aOrder = a.data.order ?? Number.MAX_SAFE_INTEGER;
  const bOrder = b.data.order ?? Number.MAX_SAFE_INTEGER;

  if (aOrder !== bOrder) return aOrder - bOrder;
  return b.data.year - a.data.year;
});

const selectedProjects = projects.filter((project) => project.data.featured).slice(0, 3);
const impressionPreview = impressions.slice(0, 4);
---

<BaseLayout>
  <SiteHeader links={homeNavigation} />

  <main id="main" tabindex="-1">
    <HomeHero content={homeContent.hero} />
    <HomeSelectedWork
      title={homeContent.selectedWork.title}
      intro={homeContent.selectedWork.intro}
      cta={homeContent.selectedWork.allProjectsCta}
      projects={selectedProjects}
    />
    <HomeProfile content={homeContent.profile} />
    <HomeImpressions content={homeContent.impressions} images={impressionPreview} />
    <HomeContact content={homeContent.contact} />
  </main>

  <SiteFooter />
</BaseLayout>

