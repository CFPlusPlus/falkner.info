---
import {
  getProjectHighlights,
  getProjectStatusLabel,
  type ProjectEntry,
} from "../../lib/projects";

type Props = {
  project: ProjectEntry;
  class?: string;
};

const { project, class: className = "" } = Astro.props as Props;
const highlights = getProjectHighlights(project).slice(0, 4);
---

<aside
  class={`reveal mt-14 border-t border-border/60 pt-7 xl:sticky xl:top-28 xl:mt-0 xl:self-start xl:border-t-0 xl:border-l xl:pt-0 xl:pl-8 ${className}`.trim()}
  style="--reveal-delay: 260ms"
>
  <div class="space-y-7">
    <section>
      <p class="meta">Fakten</p>
      <dl class="mt-4 space-y-5">
        <div>
          <dt class="text-[0.72rem] uppercase tracking-[0.12em] text-muted/72">Status</dt>
          <dd class="mt-2 text-[0.98rem] leading-[1.6] text-text/94">
            {getProjectStatusLabel(project)}
          </dd>
        </div>

        <div>
          <dt class="text-[0.72rem] uppercase tracking-[0.12em] text-muted/72">Jahr</dt>
          <dd class="mt-2 text-[0.98rem] leading-[1.6] text-text/94">
            {project.data.year}
          </dd>
        </div>

        {
          project.data.role ? (
            <div>
              <dt class="text-[0.72rem] uppercase tracking-[0.12em] text-muted/72">Rolle</dt>
              <dd class="mt-2 max-w-[26rem] text-[0.95rem] leading-[1.72] text-muted xl:max-w-[18rem]">
                {project.data.role}
              </dd>
            </div>
          ) : null
        }
      </dl>
    </section>

    {
      project.data.focus ? (
        <section class="border-t border-border/44 pt-6">
          <p class="meta">Fokus</p>
          <p class="mt-3 max-w-[26rem] text-[0.96rem] leading-[1.74] text-text/92 xl:max-w-[18rem]">
            {project.data.focus}
          </p>
        </section>
      ) : null
    }

    {
      highlights.length ? (
        <section class="border-t border-border/44 pt-6">
          <p class="meta">Highlights</p>
          <ul class="mt-4 space-y-3">
            {highlights.map((item) => (
              <li class="flex gap-3">
                <span
                  aria-hidden="true"
                  class="mt-[0.55rem] h-[0.34rem] w-[0.34rem] rounded-full bg-accent/70"
                ></span>
                <span class="max-w-[26rem] text-[0.92rem] leading-[1.68] text-muted xl:max-w-[18rem]">
                  {item}
                </span>
              </li>
            ))}
          </ul>
        </section>
      ) : null
    }
  </div>
</aside>
