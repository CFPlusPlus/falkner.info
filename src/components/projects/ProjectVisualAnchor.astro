---
import type { ProjectEntry } from "../../lib/projects";
import { getProjectHeroMedia, getProjectHighlights } from "../../lib/projects";

type Props = {
  project: ProjectEntry;
  class?: string;
};

const { project, class: className = "" } = Astro.props as Props;
const media = getProjectHeroMedia(project);
const highlights = getProjectHighlights(project).slice(0, 4);
const anchorCopy =
  media?.caption ?? project.data.summaryShort ?? project.data.context;
---

<section
  class={`reveal mt-10 border-y border-border/66 ${className}`.trim()}
  style="--reveal-delay: 200ms"
  aria-labelledby="project-visual-title"
>
  <div class="grid gap-0 lg:grid-cols-[minmax(0,1.16fr)_minmax(16rem,0.52fr)]">
    <div class="min-w-0 py-5 sm:py-6 lg:py-8 lg:pr-8">
      <div class="relative overflow-hidden border border-border/70 bg-[linear-gradient(180deg,rgb(var(--color-surface-elevated))_0%,rgb(11_14_18)_100%)]">
        {
          media ? (
            <img
              src={media.src.src}
              width={media.src.width}
              height={media.src.height}
              alt={media.alt}
              loading="eager"
              decoding="async"
              class="block h-full min-h-[18rem] w-full object-cover object-top sm:min-h-[24rem] lg:min-h-[30rem]"
            />
          ) : (
            <div class="project-visual-fallback min-h-[18rem] sm:min-h-[24rem] lg:min-h-[30rem]">
              <div class="project-visual-fallback__grid" aria-hidden="true"></div>

              <div class="relative z-[1] flex h-full flex-col justify-between gap-10 p-6 sm:p-8 lg:p-10">
                <div class="max-w-[26rem]">
                  <p class="meta">Projektstruktur</p>
                  <h2
                    id="project-visual-title"
                    class="mt-4 max-w-[14ch] text-[clamp(1.8rem,3vw,2.9rem)] font-[var(--w-title)] tracking-[-0.034em] leading-[0.98] text-text"
                  >
                    {project.data.title}
                  </h2>
                  <p class="mt-4 max-w-[30rem] text-[0.98rem] leading-[1.72] text-muted">
                    {project.data.meta}
                  </p>
                </div>

                <div class="grid gap-3 sm:grid-cols-3">
                  {highlights.slice(0, 3).map((item) => (
                    <div class="border border-border/56 bg-bg/36 px-4 py-4 backdrop-blur-[2px]">
                      <p class="text-[0.8rem] leading-[1.55] text-text/92">{item}</p>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          )
        }
      </div>
    </div>

    <div class="border-t border-border/52 py-6 lg:border-t-0 lg:border-l lg:py-8 lg:pl-8">
      <p class="meta">Projektanker</p>
      {
        media ? (
          <h2
            id="project-visual-title"
            class="mt-4 max-w-[15ch] text-[clamp(1.75rem,2.4vw,2.5rem)] font-[var(--w-title)] tracking-[-0.03em] leading-[1.02]"
          >
            Sichtbarer Projektkern statt bloßer Beschreibung.
          </h2>
        ) : null
      }
      <p class="mt-4 max-w-[18rem] text-[0.98rem] leading-[1.74] text-muted">
        {anchorCopy}
      </p>

      {
        highlights.length ? (
          <ul class="mt-6 space-y-3 border-t border-border/44 pt-6">
            {highlights.map((item) => (
              <li class="flex gap-3">
                <span
                  aria-hidden="true"
                  class="mt-[0.55rem] h-[0.34rem] w-[0.34rem] rounded-full bg-accent/70"
                ></span>
                <span class="text-[0.92rem] leading-[1.68] text-text/92">{item}</span>
              </li>
            ))}
          </ul>
        ) : null
      }
    </div>
  </div>
</section>

<style>
  .project-visual-fallback {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(
        720px 420px at 82% 14%,
        rgb(var(--color-accent) / 0.16),
        transparent 66%
      ),
      linear-gradient(180deg, rgb(15 19 23) 0%, rgb(10 12 15) 100%);
  }

  .project-visual-fallback__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgb(var(--color-border) / 0.4) 1px, transparent 1px),
      linear-gradient(90deg, rgb(var(--color-border) / 0.28) 1px, transparent 1px);
    background-size: 100% 7.75rem, 7.75rem 100%;
    mask-image: linear-gradient(180deg, rgb(255 255 255 / 0.94), transparent 94%);
    opacity: 0.44;
  }
</style>
