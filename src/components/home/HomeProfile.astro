---
import Button from "../Button.astro";
import SectionShell from "../primitives/SectionShell.astro";
import { homeContent } from "../../data/home";

type Props = {
  content: (typeof homeContent)["profile"];
};

const { content } = Astro.props as Props;
---

<SectionShell id="profil" title="Profil">
  <div class="max-w-3xl space-y-5">
    <h3 class="text-2xl sm:text-3xl font-[var(--w-title)] tracking-tight reveal">{content.title}</h3>
    {content.paragraphs.map((paragraph, index) => (
      <p class="text-base text-muted leading-relaxed reveal" style={`--reveal-delay: ${70 + index * 70}ms`}>
        {paragraph}
      </p>
    ))}
  </div>

  <div class="mt-8 reveal" style="--reveal-delay: 180ms">
    <Button href={content.cta.href} variant="secondary">{content.cta.label}</Button>
  </div>
</SectionShell>
