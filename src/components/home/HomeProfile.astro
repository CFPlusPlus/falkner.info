---
import Button from "../Button.astro";
import SectionShell from "../primitives/SectionShell.astro";
import { homeContent } from "../../data/home";

type Props = {
  content: (typeof homeContent)["profile"];
};

const { content } = Astro.props as Props;
---

<SectionShell id="profil" title="Profil">
  <div class="max-w-3xl space-y-6">
    <h3
      class="text-[clamp(1.95rem,2.9vw,2.65rem)] font-[var(--w-title)] tracking-[-0.03em] leading-[1.08] reveal"
    >
      {content.title}
    </h3>
    {
      content.paragraphs.map((paragraph, index) => (
        <p
          class="text-[clamp(1.02rem,1.15vw,1.1rem)] text-muted leading-[1.78] reveal"
          style={`--reveal-delay: ${70 + index * 70}ms`}
        >
          {paragraph}
        </p>
      ))
    }
  </div>

  <div class="mt-8 reveal" style="--reveal-delay: 180ms">
    <Button href={content.cta.href} variant="secondary"
      >{content.cta.label}</Button
    >
  </div>
</SectionShell>
