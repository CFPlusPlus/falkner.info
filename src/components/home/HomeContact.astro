---
import SectionShell from "../primitives/SectionShell.astro";
import { site } from "../../data/site";
import { homeContent } from "../../data/home";

type Props = {
  content: (typeof homeContent)["contact"];
};

const { content } = Astro.props as Props;
---

<SectionShell
  id="kontakt"
  title={content.title}
  intro={content.text}
  class="pt-[clamp(5rem,7.4vw,7.2rem)] pb-[clamp(4.2rem,6.2vw,5.8rem)]"
>
  <div class="max-w-3xl reveal">
    <p class="meta">Direkter Kontakt</p>
    <p
      class="mt-5 max-w-2xl text-[clamp(1.15rem,2.1vw,1.55rem)] leading-[1.45] text-text"
    >
      Austausch zu Projekten, Strukturfragen und digitaler Umsetzung.
    </p>
    <a
      class="mt-6 inline-block text-[clamp(1.35rem,2.5vw,1.95rem)] font-[var(--w-title)] tracking-tight u-link"
      href={`mailto:${site.email}`}
    >
      {site.email}
    </a>
    <p class="mt-4 text-sm text-muted">
      Antwort in der Regel zeitnah per E-Mail.
    </p>
  </div>
</SectionShell>
