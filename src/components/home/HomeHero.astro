---
import { Image } from "astro:assets";
import Button from "../Button.astro";
import profileImage from "../../assets/profile.webp";
import { homeContent } from "../../data/home";

type Props = {
  content: (typeof homeContent)["hero"];
};

const { content } = Astro.props as Props;
---

<section
  id="top"
  class="pt-[var(--space-hero-top)] pb-[var(--space-hero-bottom)]"
>
  <div class="mx-auto max-w-[80rem] px-5 sm:px-6 min-[1440px]:max-w-[84rem]">
    <div
      class="grid gap-12 sm:gap-14 lg:grid-cols-[minmax(0,1.5fr)_minmax(18.5rem,0.88fr)] lg:items-center lg:gap-12 xl:grid-cols-[minmax(0,1.58fr)_minmax(22rem,0.86fr)] xl:items-end xl:gap-16 min-[1440px]:grid-cols-[minmax(0,1.62fr)_minmax(23.5rem,0.84fr)]"
    >
      <div class="max-w-[46rem] reveal xl:max-w-[48rem]">
        <p class="meta">{content.eyebrow}</p>

        <h1
          class="mt-6 max-w-[10.9ch] text-[clamp(2.9rem,6.8vw,5.65rem)] font-[530] tracking-[-0.042em] leading-[0.96] text-text [text-wrap:balance] sm:max-w-[11.2ch] sm:leading-[0.97] xl:max-w-[11ch] min-[1440px]:max-w-[10.8ch]"
        >
          {content.headline}
        </h1>

        <p
          class="mt-7 max-w-[35rem] text-[clamp(1.05rem,1.45vw,1.24rem)] leading-[1.7] text-muted sm:mt-8 xl:max-w-[37rem]"
        >
          {content.text}
        </p>

        <div
          class="mt-9 flex flex-wrap items-center gap-x-4 gap-y-4 sm:mt-10 sm:gap-x-5"
        >
          <Button
            href={content.primaryCta.href}
            variant="primary"
            class="min-w-[11.75rem] justify-center sm:min-w-[12.25rem]"
          >
            {content.primaryCta.label}
          </Button>
          <Button
            href={content.secondaryCta.href}
            variant="secondary"
            class="min-w-[11.75rem] justify-center sm:min-w-[12.25rem]"
          >
            {content.secondaryCta.label}
          </Button>
        </div>

        <ul
          class="mt-10 flex flex-col items-start gap-2.5 border-t border-border/70 pt-5 text-[0.88rem] leading-relaxed tracking-[0.02em] text-muted/92 sm:mt-12 sm:flex-row sm:flex-wrap sm:items-center sm:gap-x-5 sm:gap-y-3 sm:text-[0.9rem]"
        >
          {
            content.proofItems.map((item, index) => (
              <li class="inline-flex items-center gap-3">
                {index > 0 ? (
                  <span
                    aria-hidden="true"
                    class="hidden text-accent/55 sm:inline"
                  >
                    &middot;
                  </span>
                ) : null}
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <figure class="reveal lg:justify-self-end" style="--reveal-delay: 100ms">
        <div
          class="relative mx-auto w-full max-w-[20.75rem] sm:max-w-[22.5rem] lg:max-w-[23.5rem] xl:max-w-[25rem] min-[1440px]:max-w-[26rem]"
        >
          <div
            aria-hidden="true"
            class="pointer-events-none absolute inset-x-5 bottom-1 top-7 border border-border/58 bg-surface/16 sm:inset-x-6 sm:bottom-0 sm:top-8"
          >
          </div>
          <div
            aria-hidden="true"
            class="pointer-events-none absolute left-0 top-0 h-[calc(100%-2rem)] w-px bg-accent/42 sm:h-[calc(100%-2.5rem)]"
          >
          </div>
          <div
            aria-hidden="true"
            class="pointer-events-none absolute left-0 right-10 top-0 h-px bg-border/72 sm:right-12"
          >
          </div>

          <div
            class="relative px-4 pb-4 pt-5 sm:px-5 sm:pb-5 sm:pt-6 lg:px-6 lg:pb-6 lg:pt-7"
          >
            <div
              class="relative aspect-[4/5] overflow-hidden border border-border/78 bg-surface/22 shadow-[0_24px_48px_rgba(0,0,0,0.24)]"
            >
              <Image
                src={profileImage}
                alt="Portrait von Christian Falkner"
                widths={[420, 560, 760, 960]}
                sizes="(min-width: 1440px) 416px, (min-width: 1280px) 400px, (min-width: 1024px) 31vw, (min-width: 768px) 48vw, 82vw"
                loading="eager"
                fetchpriority="high"
                class="h-full w-full object-cover object-[center_26%]"
              />
              <div
                aria-hidden="true"
                class="pointer-events-none absolute inset-0 border border-white/6"
              >
              </div>
              <div
                aria-hidden="true"
                class="pointer-events-none absolute inset-x-0 top-0 h-24 bg-gradient-to-b from-black/20 to-transparent"
              >
              </div>
            </div>
          </div>
        </div>
      </figure>
    </div>
  </div>
</section>
