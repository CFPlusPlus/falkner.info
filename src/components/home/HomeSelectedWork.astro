---
import type { CollectionEntry } from "astro:content";

import Button from "../Button.astro";
import SectionShell from "../primitives/SectionShell.astro";
import { homeContent } from "../../data/home";
import {
  getProjectExternalLink,
  getProjectMetaLine,
  getProjectPrimaryLink,
} from "../../lib/projects";

type Props = {
  title: string;
  intro: string;
  cta: (typeof homeContent)["selectedWork"]["allProjectsCta"];
  featuredProject?: CollectionEntry<"projects">;
  supportingProjects: CollectionEntry<"projects">[];
};

const { title, intro, cta, featuredProject, supportingProjects } =
  Astro.props as Props;
---

<SectionShell
  id="selected-work"
  title={title}
  intro={intro}
  class="pt-[clamp(4.6rem,6.8vw,6.6rem)] pb-[clamp(5.3rem,7.8vw,7.6rem)]"
>
  {
    featuredProject
      ? (() => {
          const primaryLink = getProjectPrimaryLink(featuredProject);
          const externalLink = getProjectExternalLink(featuredProject);

          return (
            <article
              class="reveal border-y border-border/68 py-10 sm:py-12 lg:grid lg:grid-cols-[minmax(0,1.38fr)_minmax(17rem,0.74fr)] lg:items-start lg:gap-10 xl:grid-cols-[minmax(0,1.46fr)_minmax(18rem,0.68fr)] xl:gap-14"
              style="--reveal-delay: 20ms"
            >
              <div class="max-w-[49rem]">
                <p class="meta">Featured Project</p>
                <p class="mt-4 text-[0.84rem] tracking-[0.08em] text-muted/92">
                  {featuredProject.data.meta}
                </p>
                <h3 class="mt-5 max-w-[12ch] text-[clamp(2.7rem,4.4vw,4.4rem)] font-[var(--w-title)] tracking-[-0.04em] leading-[0.96] xl:max-w-[13ch]">
                  {featuredProject.data.title}
                </h3>
                <p class="mt-6 max-w-[39rem] text-[clamp(1.06rem,1.38vw,1.22rem)] leading-[1.78] text-muted xl:max-w-[40rem]">
                  {featuredProject.data.summary}
                </p>

                <div class="mt-7 flex flex-wrap gap-x-5 gap-y-2 text-[0.88rem] tracking-[0.04em] text-muted/92 xl:mt-8">
                  <span>{getProjectMetaLine(featuredProject)}</span>
                  <span aria-hidden="true" class="text-border/80">
                    /
                  </span>
                  <span>{featuredProject.data.tags.join(" / ")}</span>
                </div>

                <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-3 xl:mt-9">
                  <a
                    href={primaryLink.href}
                    class="group inline-flex items-center gap-3 text-[0.95rem] font-[430] tracking-[0.02em] text-text transition-colors hover:text-[rgb(var(--color-accent-soft))]"
                  >
                    <span
                      aria-hidden="true"
                      class="h-px w-12 bg-border/78 transition-colors duration-200 group-hover:bg-accent/58"
                    />
                    <span>{primaryLink.label}</span>
                    <span
                      aria-hidden="true"
                      class="transition-transform duration-200 group-hover:translate-x-1"
                    >
                      &rarr;
                    </span>
                  </a>

                  {externalLink ? (
                    <a
                      href={externalLink.href}
                      class="u-link-muted text-[0.9rem]"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      {externalLink.label}
                    </a>
                  ) : null}
                </div>
              </div>

              <div class="mt-9 border-t border-border/52 pt-6 lg:mt-1 lg:min-h-[16rem] lg:border-t-0 lg:border-l lg:pt-0 lg:pl-8 xl:min-h-[17rem] xl:pl-9">
                <p class="meta">Einordnung</p>
                <p class="mt-4 max-w-[18rem] text-[0.96rem] leading-[1.76] text-muted">
                  {featuredProject.data.context}
                </p>

                <div class="mt-7 space-y-6 border-t border-border/44 pt-6">
                  <div>
                    <p class="meta">Fokus</p>
                    <p class="mt-2 text-[0.94rem] leading-[1.7] text-text/92">
                      {featuredProject.data.meta}
                    </p>
                  </div>

                  <div>
                    <p class="meta">Schwerpunkte</p>
                    <p class="mt-2 text-[0.9rem] leading-[1.7] text-muted">
                      {featuredProject.data.tags.join(" / ")}
                    </p>
                  </div>
                </div>
              </div>
            </article>
          );
        })()
      : null
  }

  {
    supportingProjects.length ? (
      <div class="mt-10 grid gap-x-10 gap-y-8 border-b border-border/60 pb-2 md:grid-cols-2 lg:mt-11 lg:gap-x-12">
        {supportingProjects.map((project, index) => {
          const primaryLink = getProjectPrimaryLink(project);

          return (
            <article
              class={`reveal border-t border-border/60 pt-7 sm:pt-8 ${supportingProjects.length === 1 ? "md:max-w-[40rem]" : ""}`}
              style={`--reveal-delay: ${Math.min(90 + index * 70, 220)}ms`}
            >
              <p class="meta">{getProjectMetaLine(project)}</p>
              <p class="mt-3 text-[0.82rem] tracking-[0.08em] text-muted/86">
                {project.data.meta}
              </p>
              <h3 class="mt-4 text-[clamp(1.95rem,2.5vw,2.55rem)] font-[var(--w-title)] tracking-[-0.03em] leading-[1.02]">
                {project.data.title}
              </h3>
              <p class="mt-4 max-w-[32rem] text-[1.02rem] leading-[1.72] text-muted">
                {project.data.summary}
              </p>
              <p class="mt-5 max-w-[28rem] text-[0.93rem] leading-[1.7] text-muted/88">
                {project.data.context}
              </p>

              <div class="mt-5 flex flex-wrap items-center justify-between gap-4">
                <p class="text-[0.88rem] tracking-[0.03em] text-muted/88">
                  {project.data.tags.join(" / ")}
                </p>
                <a
                  href={primaryLink.href}
                  class="group inline-flex items-center gap-2 text-[0.9rem] text-muted transition-colors hover:text-text"
                >
                  <span>{primaryLink.label}</span>
                  <span
                    aria-hidden="true"
                    class="transition-transform duration-200 group-hover:translate-x-1"
                  >
                    &rarr;
                  </span>
                </a>
              </div>
            </article>
          );
        })}
      </div>
    ) : null
  }

  <div class="mt-10 reveal" style="--reveal-delay: 160ms">
    <Button href={cta.href} variant="ghost">{cta.label}</Button>
  </div>
</SectionShell>
