---
import type { NavLink } from "../../data/navigation";
import { site } from "../../data/site";
import { socialLinks } from "../../data/social";
import Icon from "../Icon.astro";

type Props = {
  brand?: string;
  links: ReadonlyArray<NavLink>;
};

const { brand = site.author, links } = Astro.props as Props;

const baseUrl = import.meta.env.BASE_URL;
const resolveHref = (href: string) =>
  href.startsWith("/") && !href.startsWith(baseUrl)
    ? `${baseUrl}${href.slice(1)}`
    : href;

const homeHref = resolveHref("/");
const githubHref = socialLinks.find((link) => link.label === "GitHub")?.href;
---

<header class="sticky top-0 z-50">
  <div
    class="border-b border-border/75 bg-bg/92 backdrop-blur-[8px] supports-[backdrop-filter]:bg-bg/86"
  >
    <div class="mx-auto max-w-[80rem] px-5 sm:px-6 min-[1440px]:max-w-[84rem]">
      <div class="flex h-[4.5rem] items-center justify-between gap-6">
        <a
          href={homeHref}
          class="text-[1rem] tracking-[-0.02em] text-text font-[var(--w-title)]"
          aria-label="Zur Startseite"
        >
          {brand}
        </a>

        <div class="hidden md:flex items-center gap-9">
          <nav class="flex items-center gap-7" aria-label="Navigation">
            {
              links.map((link) => (
                <a
                  href={resolveHref(link.href)}
                  data-nav-link
                  data-target={link.targetId || ""}
                  class="navlink py-2 text-[0.92rem] tracking-[0.02em] text-muted transition-colors duration-200 hover:text-text"
                >
                  {link.label}
                </a>
              ))
            }
          </nav>

          {
            githubHref ? (
              <a
                href={githubHref}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 py-2 text-[0.86rem] tracking-[0.04em] text-muted transition-colors duration-200 hover:text-text"
              >
                GitHub
                <Icon name="arrow-up-right" size={14} strokeWidth={1.4} />
              </a>
            ) : null
          }
        </div>

        <button
          type="button"
          id="menuBtn"
          class="md:hidden inline-flex h-10 w-10 items-center justify-center rounded-sm border border-border/80 bg-surface-elevated/65 text-text transition-colors duration-200 hover:border-border hover:bg-surface-elevated"
          aria-label="Menü öffnen"
          aria-expanded="false"
          aria-controls="mobileMenu"
        >
          <Icon name="menu-2" size={20} strokeWidth={1.4} />
          <span class="sr-only">Menü</span>
        </button>
      </div>
    </div>
  </div>

  <div
    id="mobileMenu"
    class="fixed inset-0 z-[60] hidden"
    aria-hidden="true"
    role="dialog"
    aria-modal="true"
    aria-label="Navigation"
    tabindex="-1"
  >
    <div id="menuOverlay" class="absolute inset-0 bg-bg/72"></div>
    <div
      class="absolute right-0 top-0 h-full w-full max-w-sm border-l border-border/80 bg-surface"
    >
      <div class="flex h-full flex-col p-5">
        <div class="flex items-center justify-between">
          <div class="meta">Navigation</div>
          <button
            type="button"
            id="menuClose"
            class="inline-flex h-10 w-10 items-center justify-center rounded-sm border border-border/80 bg-surface-elevated/65 text-text transition-colors duration-200 hover:border-border hover:bg-surface-elevated"
            aria-label="Menü schließen"
          >
            <Icon name="x" size={20} strokeWidth={1.4} />
            <span class="sr-only">Schließen</span>
          </button>
        </div>

        <div class="mt-8 flex-1 space-y-2">
          {
            links.map((link) => (
              <a
                href={resolveHref(link.href)}
                class="block border-b border-border/70 py-4 text-base text-text"
                data-mobile-link
              >
                <span class="font-[var(--w-title)]">{link.label}</span>
              </a>
            ))
          }
        </div>

        {
          githubHref ? (
            <a
              href={githubHref}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-6 inline-flex items-center gap-2 text-sm text-muted transition-colors duration-200 hover:text-text"
              data-mobile-link
            >
              GitHub
              <Icon name="arrow-up-right" size={15} strokeWidth={1.4} />
            </a>
          ) : null
        }
      </div>
    </div>
  </div>

  <style>
    :global(a.navlink[data-active="true"]) {
      color: rgb(var(--color-text));
      position: relative;
    }

    :global(a.navlink[data-active="true"]::after) {
      content: "";
      position: absolute;
      left: 0.05em;
      right: 0.05em;
      bottom: 4px;
      height: 1px;
      background: rgb(var(--color-accent) / 0.72);
      transform-origin: left;
      animation: line-in 520ms ease-out both;
    }

    @media (prefers-reduced-motion: reduce) {
      :global(a.navlink[data-active="true"]::after) {
        animation: none;
      }
    }
  </style>
</header>
