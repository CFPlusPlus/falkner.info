---
import { site } from "../../data/site";
import { socialLinks } from "../../data/social";

const year = new Date().getFullYear();

const baseUrl = import.meta.env.BASE_URL;
const withBase = (href: string) =>
  href.startsWith("/") && !href.startsWith(baseUrl)
    ? `${baseUrl}${href.slice(1)}`
    : href;

const legalLinks = [
  { label: "Impressum", href: "/impressum" },
  { label: "Datenschutz", href: "/datenschutz" },
];
---

<footer class="border-t border-border/55 bg-transparent">
  <div
    class="mx-auto max-w-[80rem] px-5 py-8 sm:px-6 sm:py-10 min-[1440px]:max-w-[84rem]"
  >
    <div
      class="flex flex-col gap-5 sm:flex-row sm:items-center sm:justify-between"
    >
      <p class="text-sm text-muted">
        © {year}
        {site.author}
      </p>

      <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm">
        {
          legalLinks.map((link) => (
            <a href={withBase(link.href)} class="u-link-muted">
              {link.label}
            </a>
          ))
        }
        {
          socialLinks.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="u-link-muted"
            >
              {link.label}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</footer>
