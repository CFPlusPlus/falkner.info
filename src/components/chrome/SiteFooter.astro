---
import Divider from "../Divider.astro";
import Icon from "../Icon.astro";
import { iconForLabel } from "../../lib/icons";
import { site } from "../../data/site";
import { socialLinks } from "../../data/social";

const year = new Date().getFullYear();

const baseUrl = import.meta.env.BASE_URL;
const withBase = (href: string) =>
  href.startsWith("/") && !href.startsWith(baseUrl) ? `${baseUrl}${href.slice(1)}` : href;

const footerLinks = [
  ...socialLinks,
  { label: "Impressum", href: "/impressum" },
  { label: "Datenschutz", href: "/datenschutz" },
];
---

<footer class="border-t border-border/70 bg-bg/35">
  <div class="mx-auto max-w-6xl px-5 py-14">
    <div class="grid gap-10 lg:grid-cols-[1.2fr_0.8fr]">
      <div>
        <p class="meta">Kontakt</p>
        <h2 class="mt-2 text-2xl font-[var(--w-title)] tracking-tight">
          Austausch zu Projekten und digitalen Themen
        </h2>
        <p class="mt-4 text-muted leading-relaxed max-w-2xl">
          Direkter Kontakt per E-Mail unter
          <a class="u-link" href={`mailto:${site.email}`}>{site.email}</a>.
        </p>
      </div>

      <div>
        <p class="meta">Verweise</p>
        <Divider class="mt-3" />
        <ul class="mt-4 space-y-2">
          {footerLinks.map((link) => (
            <li>
              <a
                href={withBase(link.href)}
                target={link.href.startsWith("/") ? undefined : "_blank"}
                rel={link.href.startsWith("/") ? undefined : "noopener noreferrer"}
                class="group inline-flex items-center gap-2 text-sm text-muted hover:text-text transition-colors">
                <Icon name={iconForLabel(link.label)} size={16} class="text-muted group-hover:text-text transition-colors" />
                <span>{link.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <Divider class="mt-10" />

    <div class="mt-5 flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-sm text-muted">(c) {year} {site.author}</p>
      <p class="text-xs text-muted">
        falkner.info - ruhige digitale Gestaltung mit technischer Praezision
      </p>
    </div>
  </div>
</footer>
