---
type Props = {
  id: string;
  title: string;
  intro?: string;
  class?: string;
};

const { id, title, intro, class: className = "" } = Astro.props as Props;
---

<section id={id} aria-labelledby={`${id}-title`} class={`py-14 sm:py-20 ${className}`}>
  <div class="mx-auto max-w-6xl px-5">
    <div class="max-w-3xl reveal">
      <h2 id={`${id}-title`} class="text-3xl sm:text-4xl font-[var(--w-title)] tracking-tight">
        {title}
      </h2>
      {intro ? <p class="mt-4 text-base text-muted leading-relaxed">{intro}</p> : null}
    </div>
    <div class="mt-10">
      <slot />
    </div>
  </div>
</section>
