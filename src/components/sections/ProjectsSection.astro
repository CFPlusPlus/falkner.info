---
import Section from "../Section.astro";
import Divider from "../Divider.astro";
import ProjectSpotlight from "../ProjectSpotlight.astro";
import ProjectList from "../ProjectList.astro";

import type { Project } from "../../lib/site";

type Props = {
  spotlightProject: Project;
  projects: Project[];
  serverAddress: string;
};

const { spotlightProject, projects, serverAddress } = Astro.props;
---

<Section
  id="projects"
  title="Projekte"
  kicker="Dinge, an denen ich arbeite"
  lead="Hier stehen die konkreten Anlaufstellen: Seiten, Communities und kleine Webprojekte, die ich betreue, weiterentwickle oder als persönlichen Ausgangspunkt nutze.">
  <div class="space-y-10">
    <div class="reveal">
      <ProjectSpotlight project={spotlightProject} serverAddress={serverAddress} />
    </div>

    <div class="reveal" style="--reveal-delay: 80ms">
      <div class="meta">Mehr</div>
      <Divider class="mt-3" />
      <div class="mt-6">
        <ProjectList projects={projects} />
      </div>
    </div>
  </div>
</Section>
